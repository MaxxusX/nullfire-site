{
	"extends": "astro/tsconfigs/strictest",
	"include": [".astro/types.d.ts", "**/*"],
	"exclude": ["dist"],
	"compilerOptions": {
		"types": ["node"],
		"paths": {
			"@assets/*": ["./src/assets/*"],
			"@styles/*": ["./src/styles/*"],
			"@components/*": ["./src/components/*"],
			"@layouts/*": ["./src/layouts/*"],
			"@pages/*": ["./src/pages/*"]
		}
	}
}
