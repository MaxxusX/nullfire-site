{
	"$schema": "https://www.schemastore.org/prettierrc.json",
	"experimentalTernaries": true,
	"printWidth": 100,
	"tabWidth": 4,
	"useTabs": true,
	"quoteProps": "as-needed",
	"trailingComma": "es5",
	"objectWrap": "collapse",
	"proseWrap": "always",
	"vueIndentScriptAndStyle": true,
	"plugins": ["prettier-plugin-astro"],
	"overrides": [
		{
			"files": "*.astro",
			"options": {
				"parser": "astro"
			}
		},
		{
			"files": ["*.md", "*.json"],
			"options": {
				"tabWidth": 2
			}
		},
		{
			"files": [".*", "*.txt", "*.yml", "*.yaml", "*.toml", "_headers", "_redirects"],
			"options": {
				"tabWidth": 2,
				"useTabs": false
			}
		},
		{
			"files": [".vscode/*.json", "tsconfig.json"],
			"options": {
				"parser": "jsonc"
			}
		}
	]
}
