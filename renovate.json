{
	"$schema": "https://docs.renovatebot.com/renovate-schema.json",
	"extends": ["config:recommended", "abandonments:recommended", "mergeConfidence:all-badges"],
	"ignorePresets": [":semanticPrefixFixDepsChoreOthers"],
	"enabledManagers": ["custom.jsonata", "npm", "github-actions", "renovate-config"],
	"customManagers": [
		{
			"customType": "jsonata",
			"fileFormat": "json",
			"managerFilePatterns": ["package.json"],
			"matchStrings": [
				"{ 'currentValue': devEngines.packageManager.version }"
			],
			"depNameTemplate": "pnpm",
			"datasourceTemplate": "npm",
			"depTypeTemplate": "packageManager",
			"versioningTemplate": "semver"
		}
	],
	"constraints": {
		"node": "^26.3.1"
	},
	"configMigration": true,
	"assignees": ["MaxxusX"],
	"reviewers": ["MaxxusX"],
	"labels": ["dependencies"],
	"semanticCommits": "enabled",
	"semanticCommitType": "chore",
	"prHourlyLimit": 0,
	"rangeStrategy": "bump",
	"vulnerabilityAlerts": {
		"enabled": true,
		"rangeStrategy": "bump"
	},
	"lockFileMaintenance": {
		"enabled": true,
		"schedule": ["before 8am on friday"]
	},
	"npm": {
		"enabled": true
	},
	"postUpdateOptions": ["pnpmDedupe"],
	"packageRules": [
		{
			"matchManagers": ["renovate-config"],
			"matchDepTypes": ["tool-constraint"],
			"matchDepNames": ["node"],
			"enabled": false
		},
		{
			"matchDepTypes": ["action"],
			"matchPackageNames": ["pnpm/action-setup"],
			"pinDigests": true
		},
		{
			"matchDatasources": ["npm"],
			"minimumReleaseAge": "1 days",
			"internalChecksFilter": "strict"
		},
		{
			"matchManagers": ["npm"],
			"addLabels": ["javascript"]
		},
		{
			"matchManagers": ["github-actions"],
			"addLabels": ["github_actions"]
		},
		{
			"matchManagers": ["custom.jsonata"],
			"matchDepTypes": ["packageManager"],
			"matchDepNames": ["pnpm"],
			"commitMessageTopic": "pnpm",
			"addLabels": ["javascript"]
		}
	]
}
